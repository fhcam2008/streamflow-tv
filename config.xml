<?xml version="1.0" encoding="UTF-8"?>
<widget xmlns="http://www.w3.org/ns/widgets"
        xmlns:tizen="http://tizen.org/ns/widgets"
        id="http://yourdomain.com/StreamFlowTV"
        version="2.0.0"
        viewmodes="fullscreen">

  <tizen:application id="STREAMFL.StreamFlowTV"
                     package="STREAMFL"
                     required_version="3.0"/>

  <content src="index.html"/>

  <tizen:privilege name="http://tizen.org/privilege/internet"/>
  <tizen:privilege name="http://tizen.org/privilege/application.launch"/>
  <tizen:privilege name="http://tizen.org/privilege/tv.inputdevice"/>
  <tizen:privilege name="http://tizen.org/privilege/tv.display"/>

  <tizen:profile name="tv"/>

  <tizen:metadata key="http://developer.samsung.com/tizen/metadata/drmtype" value="none"/>

  <n>StreamFlow TV</n>
  <description>IPTV Player with Xtream Codes API + M3U, VOD sync, metadata</description>

  <tizen:setting screen-orientation="landscape"
                 context-menu="disable"
                 background-support="disable"
                 encryption="disable"
                 install-location="internal-only"
                 hw-key-event="enable"/>

  <feature name="http://tizen.org/feature/network.internet" required="true"/>
  <access origin="*" subdomains="true"/>
</widget>
